# npm audit configuration
# Suppress advisories for AWS Amplify bundled transitive dependencies.
# These are CDK construct libraries used only at build/deploy time — they
# never ship to the browser. The vulnerable packages (fast-xml-parser, lodash,
# @smithy/config-resolver, @aws-sdk/*) are nested inside
# @aws-amplify/data-construct and @aws-amplify/graphql-api-construct and
# cannot be overridden via package.json "overrides".
#
# Setting audit-level to "critical" means npm audit will only fail for
# critical-severity vulnerabilities. The remaining 24 vulnerabilities
# (14 low, 10 high) are all in Amplify CDK construct bundled deps that
# are build-time only and never reach the browser.
audit-level=critical