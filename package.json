{
  "name": "amplify-vite-react-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "check": "tsc --noEmit && eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0 && npm run test",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "preview": "vite preview"
  },
  "dependencies": {
    "@aws-amplify/ui-react": "~6.15.3",
    "aws-amplify": "~6.16.4",
    "lucide-react": "^1.8.0",
    "react": "~18.3.1",
    "react-dom": "~18.3.1"
  },
  "engines": {
    "node": ">= 22.12.0",
    "npm": ">= 10.8.0"
  },
  "devDependencies": {
    "@aws-amplify/backend": "~1.22.0",
    "@aws-amplify/backend-cli": "~1.8.2",
    "@eslint/compat": "~2.0.1",
    "@eslint/eslintrc": "~3.3.3",
    "@eslint/js": "~9.39.2",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/react": "~18.3.27",
    "@types/react-dom": "~18.3.7",
    "@typescript-eslint/eslint-plugin": "~8.53.0",
    "@typescript-eslint/parser": "~8.53.0",
    "@vitejs/plugin-react": "~5.1.2",
    "autoprefixer": "^10.4.27",
    "esbuild": "~0.27.2",
    "eslint": "~9.39.2",
    "eslint-plugin-react-hooks": "~7.0.1",
    "eslint-plugin-react-refresh": "~0.4.26",
    "globals": "~17.0.0",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "~7.3.1"
  },
  "overrides": {
    "fast-xml-parser": "^5.5.7",
    "handlebars": "^4.7.8",
    "lodash": "^4.17.21",
    "immutable": "^3.8.3",
    "@smithy/config-resolver": "^4.4.0"
  }
}
